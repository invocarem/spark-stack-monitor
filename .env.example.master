# Spark Stack Monitor — head node (192.168.100.11).
# Copy to `.env` on this machine only (`cp .env.example.head .env`), then edit NIC names to match `ip link`.

MONITOR_CLUSTER_APPLY=true

# Head: often uses this host’s cluster NIC (example — replace with yours).
MONITOR_CLUSTER_NCCL_SOCKET_IFNAME=enp1s0f1np1
MONITOR_CLUSTER_GLOO_SOCKET_IFNAME=enp1s0f1np1

# Rendezvous: usually head’s IP + same port as SGLang --dist-init-addr.
MONITOR_CLUSTER_MASTER_ADDR=192.168.100.11
MONITOR_CLUSTER_MASTER_PORT=50000
MONITOR_CLUSTER_DIST_INIT_ADDR=192.168.100.11:50000

MONITOR_CLUSTER_NNODES=2
MONITOR_CLUSTER_NODE_RANK=0

# Optional: passed into Container-tab `docker run` (with MONITOR_CLUSTER_APPLY set). See run_master.sh.
# CUDA_VISIBLE_DEVICES=0
# NCCL_DEBUG=INFO
# MONITOR_CLUSTER_NCCL_IB_DISABLE=0
# NCCL_IB_GID_INDEX=3
# MONITOR_CLUSTER_WORLD_SIZE=2
# NCCL_IB_TIMEOUT=22
# NCCL_IB_RETRY_CNT=7
# NCCL_ASYNC_ERROR_HANDLING=1
# NCCL_BLOCKING_WAIT=1
# TORCH_DISTRIBUTED_TIMEOUT=1800
