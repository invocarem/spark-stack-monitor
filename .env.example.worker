# Spark Stack Monitor — worker node (192.168.100.12).
# Copy to `.env` on this machine only (`cp .env.example.worker .env`), then edit NIC names to match `ip link`.

MONITOR_CLUSTER_APPLY=true

# Worker: use this machine’s cluster NIC (example — replace with yours).
MONITOR_CLUSTER_NCCL_SOCKET_IFNAME=enp1s0f0np0
MONITOR_CLUSTER_GLOO_SOCKET_IFNAME=enp1s0f0np0

# Rendezvous still points at the head (rank-0) node.
MONITOR_CLUSTER_MASTER_ADDR=192.168.100.11
MONITOR_CLUSTER_MASTER_PORT=50000
MONITOR_CLUSTER_DIST_INIT_ADDR=192.168.100.11:50000

MONITOR_CLUSTER_NNODES=2
MONITOR_CLUSTER_NODE_RANK=1

# Optional: stack `docker run` env (with MONITOR_CLUSTER_APPLY set). Worker often disables IB; see run_worker.sh.
# MONITOR_CLUSTER_NCCL_IB_DISABLE=1
# NCCL_IB_DISABLE=1
